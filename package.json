{
  "name": "docedit",
  "version": "1.0.0",
  "description": "Collaborative document editor",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"node src/server/index.js\" \"vite\"",
    "dev:server": "node src/server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node src/server/index.js",
    "test": "node --test src/tests/*.test.js"
  },
  "keywords": [],
